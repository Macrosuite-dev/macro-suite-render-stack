# License API
API_ENVIRONMENT=production
API_APP_NAME=Macro Suite License API
DATABASE_URL=postgresql://macro_suite_license:replace-me@your-render-postgres-host:5432/macro_suite_license
PUBLIC_BASE_URL=https://macro-suite-license-api.onrender.com
DASHBOARD_BASE_URL=https://macro-suite-license-admin.onrender.com
# Set the same ADMIN_API_TOKEN value on both the API service and the dashboard service.
ADMIN_API_TOKEN=replace-with-a-long-random-token
LICENSE_KEY_SECRET=replace-with-a-long-random-secret
ACTIVATION_TOKEN_SECRET=replace-with-a-long-random-secret
ACTIVATION_TOKEN_ISSUER=macro-suite-license
ACTIVATION_TOKEN_TTL_MINUTES=30
HEARTBEAT_INTERVAL_SECONDS=15
REQUIRE_CLIENT_SIGNATURES=false
CLIENT_SIGNATURE_TTL_SECONDS=120
# Optional only if REQUIRE_CLIENT_SIGNATURES=true
CLIENT_SHARED_SECRET=
# Macro Suite timestamps and token expiries are stored and returned in UTC.

# Admin dashboard
DASHBOARD_ENVIRONMENT=production
DASHBOARD_APP_NAME=Macro Suite Admin Dashboard
DASHBOARD_PUBLIC_BASE_URL=https://macro-suite-license-admin.onrender.com
DASHBOARD_SESSION_SECRET=replace-with-a-long-random-secret
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=change-me
LICENSE_API_BASE_URL=https://macro-suite-license-api.onrender.com
# Reuse the same ADMIN_API_TOKEN value from the API service above.
