# License API
API_ENVIRONMENT=development
API_APP_NAME=Macro Suite License API
DATABASE_URL=sqlite:///./macro_suite_license.sqlite3
PUBLIC_BASE_URL=http://127.0.0.1:8000
DASHBOARD_BASE_URL=http://127.0.0.1:5000
# Use the same ADMIN_API_TOKEN value for the local API and local dashboard.
ADMIN_API_TOKEN=local-admin-api-token
LICENSE_KEY_SECRET=local-license-key-secret
ACTIVATION_TOKEN_SECRET=local-activation-token-secret
REQUIRE_CLIENT_SIGNATURES=false
CLIENT_SIGNATURE_TTL_SECONDS=120
CLIENT_SHARED_SECRET=
ACTIVATION_TOKEN_ISSUER=macro-suite-license
ACTIVATION_TOKEN_TTL_MINUTES=30
HEARTBEAT_INTERVAL_SECONDS=15

# Admin dashboard
DASHBOARD_ENVIRONMENT=development
DASHBOARD_APP_NAME=Macro Suite Admin Dashboard
DASHBOARD_PUBLIC_BASE_URL=http://127.0.0.1:5000
DASHBOARD_SESSION_SECRET=local-dashboard-session-secret
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=local-password
LICENSE_API_BASE_URL=http://127.0.0.1:8000
